# ============================================================
# UrbanFlow OSM - Variables de entorno
# Copia este archivo a .env y completa los valores.
# ============================================================

# --- Servidor ---
HOST=127.0.0.1
PORT=5050
FLASK_DEBUG=1
SECRET_KEY=cambia-esta-clave-en-produccion

# --- Base de datos ---
# Por defecto SQLite local. Para produccion usa Postgres:
#   DATABASE_URL=postgresql+psycopg://user:pass@host:5432/urbanflo
DATABASE_URL=sqlite:///urbanflow.db

# --- Seguridad / CORS ---
# Lista de origenes permitidos separados por coma. Usa * solo en desarrollo.
CORS_ORIGINS=*
# Clave de administrador creada al iniciar si no existe ninguna admin.
ADMIN_API_KEY=

# --- Google Maps Routes (rutas + trafico en ruta) ---
# https://developers.google.com/maps/documentation/routes
GOOGLE_MAPS_API_KEY=

# --- TomTom (busqueda y fallback de trafico/rutas) ---
# https://developer.tomtom.com
TOMTOM_API_KEY=

# --- Geoapify (autocomplete y fallback de rutas) ---
# https://www.geoapify.com/
GEOAPIFY_API_KEY=

# --- HERE Maps (fallback de trafico puntual) ---
# https://developer.here.com
HERE_API_KEY=

# --- SerpApi (POI y lugares desde Google Maps) ---
# https://serpapi.com/google-maps-api
SERPAPI_API_KEY=

# --- Prioridad de proveedores ---
ROUTE_PROVIDERS=google,osrm,geoapify,serpapi
SEARCH_PROVIDERS=tomtom,geoapify,nominatim
TRAFFIC_PROVIDERS=google,here,tomtom

# --- GTFS Realtime (opcional) ---
GTFS_REALTIME_VEHICLES_URL=
GTFS_REALTIME_TRIP_UPDATES_URL=
GTFS_REALTIME_ALERTS_URL=
GTFS_FEED_URL=
